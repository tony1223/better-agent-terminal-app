default_platform(:ios)

APP_IDENTIFIER = "com.tonyq.betteragentterminal"
XCODEPROJ = "BATMobile.xcodeproj"
WORKSPACE = "BATMobile.xcworkspace"
SCHEME = "BATMobile"
TEAM_ID = "8JVDJGLLYR"

platform :ios do
  desc "One-time: generate the Apple Distribution cert + App Store profile into ./signing"
  lane :bootstrap_signing do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_P8_BASE64"),
      is_key_content_base64: true,
      in_house: false,
    )

    out = File.expand_path("../signing", __dir__)
    FileUtils.mkdir_p(out)

    # Create (or reuse, if the private key is already in this keychain) the cert.
    cert(
      api_key: api_key,
      generate_apple_certs: true,
      output_path: out,
    )

    # Create / download the App Store provisioning profile for this app id.
    sigh(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      platform: "ios",
      output_path: out,
    )

    UI.success("Signing assets written to #{out}")
  end

  desc "Build a Release IPA and upload it to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_API_KEY_P8_BASE64"),
      is_key_content_base64: true,
      in_house: false,
    )

    # Create an isolated temporary keychain on CI and make it the default.
    # Exposes MATCH_KEYCHAIN_NAME / MATCH_KEYCHAIN_PASSWORD for the import below.
    setup_ci(force: true)

    # Import the Apple Distribution certificate (.p12) into the temp keychain.
    import_certificate(
      certificate_path: ENV.fetch("DIST_CERT_PATH"),
      certificate_password: ENV.fetch("DIST_CERT_PASSWORD", ""),
      keychain_name: ENV.fetch("MATCH_KEYCHAIN_NAME", "fastlane_tmp_keychain"),
      keychain_password: ENV.fetch("MATCH_KEYCHAIN_PASSWORD", ""),
    )

    # Read the provisioning profile (name + UUID) and install it where Xcode looks.
    profile_path = ENV.fetch("PROVISIONING_PROFILE_PATH")
    require "plist"
    profile = Plist.parse_xml(`security cms -D -i "#{profile_path}"`)
    profile_name = profile.fetch("Name")
    profile_uuid = profile.fetch("UUID")
    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    FileUtils.mkdir_p(profiles_dir)
    FileUtils.cp(profile_path, File.join(profiles_dir, "#{profile_uuid}.mobileprovision"))

    # CI has no logged-in Xcode account, so switch the app target to manual signing
    # pointing at the profile we just installed. Only affects the CI working copy.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      targets: [SCHEME],
      team_id: TEAM_ID,
      code_sign_identity: "Apple Distribution",
      bundle_identifier: APP_IDENTIFIER,
      profile_name: profile_name,
    )

    # Optional marketing version override (e.g. 1.0.1).
    marketing = ENV["MARKETING_VERSION"]
    unless marketing.nil? || marketing.strip.empty?
      increment_version_number(xcodeproj: XCODEPROJ, version_number: marketing.strip)
    end

    version = get_version_number(xcodeproj: XCODEPROJ, target: SCHEME)

    # Pick a build number that is guaranteed higher than what TestFlight already has.
    build_number =
      begin
        latest = latest_testflight_build_number(
          api_key: api_key,
          app_identifier: APP_IDENTIFIER,
          version: version,
          initial_build_number: 0,
        )
        (latest.to_i + 1).to_s
      rescue => e
        UI.important("Falling back on build number (#{e.message})")
        env_bn = ENV["BUILD_NUMBER"]
        (env_bn.nil? || env_bn.strip.empty?) ? Time.now.strftime("%Y%m%d%H%M") : env_bn.strip
      end

    increment_build_number(xcodeproj: XCODEPROJ, build_number: build_number)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => profile_name,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
